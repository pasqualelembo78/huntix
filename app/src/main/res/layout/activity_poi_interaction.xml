<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0D0620">

    <!-- POI icon (center, rotates on spin) -->
    <LinearLayout
        android:id="@+id/poiContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tvPoiIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:gravity="center"
            android:text="\uD83C\uDFDF\uFE0F"
            android:textSize="64sp"
            android:background="@drawable/poi_circle_bg" />

        <TextView
            android:id="@+id/tvPoiName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvPoiDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:textColor="#B0BEC5"
            android:gravity="center" />
    </LinearLayout>

    <!-- Cooldown overlay (shown after spin) -->
    <LinearLayout
        android:id="@+id/cooldownOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp"
        android:background="#CC1A1030"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvCooldown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#B0BEC5"
            android:gravity="center" />
    </LinearLayout>

    <!-- Spin button (center-bottom) -->
    <TextView
        android:id="@+id/btnSpin"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:text="\uD83C\uDF00"
        android:textSize="36sp"
        android:background="@drawable/btn_catch_bg"
        android:clickable="true"
        android:focusable="true" />

    <!-- Spin hint -->
    <TextView
        android:id="@+id/tvSpinHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="50dp"
        android:text="Tocca per girare!"
        android:textSize="13sp"
        android:textColor="#B0BEC5" />

    <!-- Back button -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="48dp"
        android:layout_marginStart="12dp"
        android:gravity="center"
        android:text="\u2190"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_accent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Reward popup (shown after successful spin) -->
    <FrameLayout
        android:id="@+id/rewardPopup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/badge_tooltip"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvRewardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ricompense!"
                android:textSize="22sp"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- MVC reward -->
            <LinearLayout
                android:id="@+id/rewardMvc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\uD83D\uDCB0"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tvRewardMvc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+50"
                    android:textSize="18sp"
                    android:textColor="#FFD700"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- XP reward -->
            <LinearLayout
                android:id="@+id/rewardXp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tvRewardXp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+100 XP"
                    android:textSize="18sp"
                    android:textColor="#00E5FF"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Item reward -->
            <LinearLayout
                android:id="@+id/rewardItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvRewardItemIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tvRewardItem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Egg reward -->
            <LinearLayout
                android:id="@+id/rewardEgg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\uD83E\uDD5A"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tvRewardEgg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uovo ottenuto!"
                    android:textSize="16sp"
                    android:textColor="#4CAF50"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Collect button -->
            <TextView
                android:id="@+id/btnCollect"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="Raccogli"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_accent"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
