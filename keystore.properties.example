# ═══════════════════════════════════════════════════════════════
# keystore.properties.example
# ═══════════════════════════════════════════════════════════════
#
# COPIA QUESTO FILE in keystore.properties e inserisci le tue chiavi.
# keystore.properties è in .gitignore — NON committarlo mai.
#
# Dove ottenere ogni chiave:
#   admobBannerId / interstitialId / rewardedId  → apps.admob.com
#   arcoreApiKey   → console.cloud.google.com → ARCore API
#   mapboxToken    → account.mapbox.com → Access tokens (pubblico pk.*)
#   mapboxDownloadsToken → account.mapbox.com → Access tokens (segreto sk.*)
#   sentryDsn      → sentry.io → Settings → Client Keys
#   webClientId    → Firebase Console → Authentication → Google → Web client ID
# ═══════════════════════════════════════════════════════════════

# ── Firma APK ─────────────────────────────────────────────
storeFile=keystore.jks
storePassword=
keyAlias=
keyPassword=

# ── Sentry ────────────────────────────────────────────────
sentryDsn=

# ── Firebase Auth ─────────────────────────────────────────
webClientId=

# ── AdMob ─────────────────────────────────────────────────
admobAppId=
admobBannerId=
admobInterstitialId=
admobRewardedId=

# ── ARCore Cloud Anchor API ───────────────────────────────
arcoreApiKey=

# ── Mapbox ────────────────────────────────────────────────
mapboxToken=
mapboxDownloadsToken=
